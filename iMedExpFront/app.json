{
  "expo": {
    "name": "iMedExp",
    "slug": "imedexp",
    "scheme": "imedexp",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "assets/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F1FAFE"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "iMedExp usa la cámara para escanear el código QR de acceso del paciente."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
